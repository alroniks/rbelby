---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');

// Prepare data for filters
const events = allEvents.map((event) => {
  const date = new Date(event.data.date);
  const year = date.getFullYear();
  const month = date.toLocaleString('default', { month: 'long' });

  return {
    ...event,
    timestamp: date.getTime(),
    year,
    month,
    dist: event.data.distance, // Short alias for data attr
    loc: event.data.startLocation || 'Unknown',
    type: event.data.type || 'road', // Default to road if undefined
  };
});

// Sort by date initially (upcoming first)
events.sort((a, b) => a.timestamp - b.timestamp);

// Extract unique values for filters
const locations = [...new Set(events.map((e) => e.loc))].sort();
const years = [...new Set(events.map((e) => e.year))].sort((a, b) => b - a);
const types = [...new Set(events.map((e) => e.type))];

function getTimeLimit(distance: number) {
  if (distance >= 1200) return '90h';
  if (distance >= 1000) return '75h';
  if (distance >= 600) return '40h';
  if (distance >= 400) return '27h';
  if (distance >= 300) return '20h';
  if (distance >= 200) return '13.5h';
  return 'N/A';
}
---

<Layout>
  <Navbar />

  <main class="min-h-screen bg-gray-50 dark:bg-neutral-900">
    <!-- Header / Filter Bar -->
    <div
      class="sticky top-0 z-20 border-b border-gray-200 bg-white shadow-sm dark:border-neutral-800 dark:bg-neutral-900"
    >
      <div class="mx-auto max-w-[85rem] px-4 py-4 sm:px-6 lg:px-8">
        <!-- Top Row: Title + Mobile Search Toggle -->
        <div class="mb-4 flex items-center justify-between lg:hidden">
          <h1 class="text-xl font-bold text-gray-800 dark:text-white">
            Events
          </h1>
          <button
            id="mobile-filter-toggle"
            class="p-2 text-gray-500 hover:text-gray-800 dark:text-gray-400 dark:hover:text-white"
          >
            <svg
              class="size-6"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75"
              ></path>
            </svg>
          </button>
        </div>

        <!-- Controls Container -->
        <div
          id="filter-controls"
          class="hidden flex-col items-start justify-between gap-4 lg:flex lg:flex-row lg:items-center"
        >
          <!-- Left: Year/Type Toggles (Reference Style Pill) -->
          <div
            class="flex items-center space-x-1 rounded-lg bg-gray-100 p-1 dark:bg-neutral-800"
          >
            <button
              class="filter-year-btn rounded-md bg-white px-4 py-1.5 text-sm font-medium text-gray-800 shadow-sm transition-all dark:bg-neutral-700 dark:text-white"
              data-year="all">All</button
            >
            {
              years.map((year) => (
                <button
                  class="filter-year-btn rounded-md px-4 py-1.5 text-sm font-medium text-gray-500 transition-all hover:text-gray-800 dark:text-gray-400 dark:hover:text-white"
                  data-year={year}
                >
                  {year}
                </button>
              ))
            }
          </div>

          <!-- Middle: Search & Dropdowns -->
          <div class="flex w-full flex-col gap-3 sm:flex-row lg:w-auto">
            <!-- Search -->
            <div class="relative w-full lg:w-64">
              <div
                class="pointer-events-none absolute inset-y-0 start-0 flex items-center ps-3"
              >
                <svg
                  class="size-4 text-gray-400 dark:text-neutral-500"
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><circle cx="11" cy="11" r="8"></circle><path
                    d="m21 21-4.3-4.3"></path></svg
                >
              </div>
              <input
                type="text"
                id="search-input"
                class="block w-full rounded-lg border-transparent bg-gray-100 py-2 ps-10 pe-4 text-sm focus:border-orange-500 focus:ring-orange-500 disabled:pointer-events-none disabled:opacity-50 dark:bg-neutral-800 dark:text-neutral-400 dark:placeholder-neutral-500"
                placeholder="Search events..."
              />
            </div>

            <!-- Distance Select -->
            <select
              id="distance-select"
              class="block w-full rounded-lg border-transparent bg-gray-100 px-3 py-2 pe-9 text-sm focus:border-orange-500 focus:ring-orange-500 sm:w-auto dark:bg-neutral-800 dark:text-neutral-400"
            >
              <option value="all">Distance: All</option>
              <option value="200">200 km</option>
              <option value="300">300 km</option>
              <option value="400">400 km</option>
              <option value="600">600 km</option>
              <option value="1000">1000+ km</option>
            </select>

            <!-- Location Select -->
            <select
              id="location-select"
              class="block w-full rounded-lg border-transparent bg-gray-100 px-3 py-2 pe-9 text-sm focus:border-orange-500 focus:ring-orange-500 sm:w-auto dark:bg-neutral-800 dark:text-neutral-400"
            >
              <option value="all">Location: All</option>
              {locations.map((loc) => <option value={loc}>{loc}</option>)}
            </select>
          </div>

          <!-- Right: Sort -->
          <div
            class="mt-2 flex w-full items-center gap-2 border-l border-gray-200 pl-0 lg:mt-0 lg:w-auto lg:pl-4 dark:border-neutral-800"
          >
            <span
              class="text-xs font-semibold text-gray-500 uppercase dark:text-neutral-500"
              >Sort by:</span
            >
            <div class="flex space-x-2">
              <button
                class="sort-btn text-sm font-medium text-orange-600 hover:underline dark:text-orange-500"
                data-sort="date">Date</button
              >
              <button
                class="sort-btn text-sm font-medium text-gray-500 transition-colors hover:text-gray-800 dark:text-gray-400 dark:hover:text-white"
                data-sort="dist">Dist</button
              >
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Events Grid -->
    <div class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8">
      <div
        id="events-grid"
        class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
      >
        {
          events.map((event) => (
            <article
              class="event-card group flex h-full flex-col overflow-hidden rounded-xl border border-gray-200 bg-white shadow-xs transition-all duration-300 hover:shadow-md dark:border-neutral-700 dark:bg-neutral-800"
              data-name={event.data.name.toLowerCase()}
              data-year={event.year}
              data-dist={event.dist}
              data-loc={event.loc}
              data-date={event.timestamp}
            >
              <div class="relative h-40 overflow-hidden">
                <img
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  src="https://images.unsplash.com/photo-1559166631-ef208440c75a?q=80&w=600&auto=format&fit=crop"
                  alt={event.data.name}
                />
                <div class="absolute top-3 right-3">
                  <span class="inline-flex items-center gap-x-1 rounded-lg bg-white/90 px-2 py-1 text-xs font-medium text-gray-800 shadow-sm backdrop-blur-sm dark:bg-neutral-900/90 dark:text-white">
                    {event.data.type || 'Road'}
                  </span>
                </div>
              </div>

              <div class="flex flex-grow flex-col p-5">
                <div class="mb-2 flex items-start justify-between">
                  <span class="text-xs font-bold tracking-wider text-orange-600 uppercase dark:text-orange-500">
                    {event.month} {new Date(event.data.date).getDate()}
                  </span>
                  <span class="text-xs text-gray-500 dark:text-gray-400">
                    {event.loc}
                  </span>
                </div>

                <h3 class="mb-1 text-xl font-bold text-gray-800 transition-colors group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-500">
                  <a href={`/events/${event.id}`}>{event.data.name}</a>
                </h3>

                <p class="mt-auto flex items-center gap-4 border-t border-gray-100 pt-4 text-sm text-gray-600 dark:border-neutral-700 dark:text-gray-300">
                  <span class="flex items-center gap-1 font-semibold">
                    <svg
                      class="size-4"
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="1.5"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
                      />
                    </svg>
                    {getTimeLimit(event.dist)}
                  </span>
                  <span class="flex items-center gap-1 font-semibold">
                    <svg
                      class="size-4"
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="1.5"
                      stroke="currentColor"
                    >
                      <>
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"
                        />
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
                        />
                      </>
                    </svg>
                    {event.dist} km
                  </span>
                </p>
              </div>
            </article>
          ))
        }
      </div>

      <!-- No Results State -->
      <div id="no-results" class="hidden py-20 text-center">
        <div
          class="mb-4 inline-flex size-16 items-center justify-center rounded-full bg-gray-100 dark:bg-neutral-800"
        >
          <svg
            class="size-6 text-gray-400"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
            ></path></svg
          >
        </div>
        <h3 class="text-lg font-semibold text-gray-800 dark:text-white">
          No events found
        </h3>
        <p class="text-gray-500 dark:text-gray-400">
          Try adjusting your search or filters.
        </p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  // Simple Vanilla JS for Client-Side Filtering
  document.addEventListener('DOMContentLoaded', () => {
    const grid = document.getElementById('events-grid');
    const cards = document.querySelectorAll('.event-card');
    const noResults = document.getElementById('no-results');

    // Controls
    const searchInput = document.getElementById('search-input');
    const yearBtns = document.querySelectorAll('.filter-year-btn');
    const distanceSelect = document.getElementById('distance-select');
    const locationSelect = document.getElementById('location-select');
    const sortBtns = document.querySelectorAll('.sort-btn');
    const mobileToggle = document.getElementById('mobile-filter-toggle');
    const filterControls = document.getElementById('filter-controls');

    let currentFilters = {
      search: '',
      year: 'all',
      distance: 'all',
      location: 'all',
      sort: 'date', // date | dist
    };

    // --- Filter Logic ---
    function applyFilters() {
      let visibleCount = 0;
      const cardsArray = Array.from(cards);

      // 1. Filter
      cardsArray.forEach((card) => {
        const name = card.dataset.name;
        const year = card.dataset.year;
        const dist = parseInt(card.dataset.dist);
        const loc = card.dataset.loc;

        let matchesSearch = name.includes(currentFilters.search.toLowerCase());
        let matchesYear =
          currentFilters.year === 'all' || year === currentFilters.year;
        let matchesLoc =
          currentFilters.location === 'all' || loc === currentFilters.location;

        let matchesDist = true;
        if (currentFilters.distance !== 'all') {
          const targetDist = parseInt(currentFilters.distance);
          if (targetDist === 1000) matchesDist = dist >= 1000;
          else matchesDist = dist === targetDist;
        }

        if (matchesSearch && matchesYear && matchesLoc && matchesDist) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      // 2. Sort Visible Cards
      // We can re-append them to the grid in order
      // NOTE: This re-sorting logic operates on the DOM elements directly
      const sortedCards = cardsArray
        .filter((c) => !c.classList.contains('hidden'))
        .sort((a, b) => {
          const valA = parseInt(a.dataset[currentFilters.sort]);
          const valB = parseInt(b.dataset[currentFilters.sort]);
          return valA - valB;
        });

      // Append sorted cards back to grid (moves them)
      sortedCards.forEach((card) => grid.appendChild(card));

      // 3. Toggle Empty State
      if (visibleCount === 0) {
        noResults.classList.remove('hidden');
      } else {
        noResults.classList.add('hidden');
      }
    }

    // --- Event Listeners ---

    // Search
    searchInput.addEventListener('input', (e) => {
      currentFilters.search = e.target.value;
      applyFilters();
    });

    // Year Toggle
    yearBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        // Update UI
        yearBtns.forEach((b) => {
          b.classList.remove(
            'bg-white',
            'dark:bg-neutral-700',
            'text-gray-800',
            'dark:text-white',
            'shadow-sm'
          );
          b.classList.add('text-gray-500', 'dark:text-gray-400');
        });
        btn.classList.add(
          'bg-white',
          'dark:bg-neutral-700',
          'text-gray-800',
          'dark:text-white',
          'shadow-sm'
        );
        btn.classList.remove('text-gray-500', 'dark:text-gray-400');

        currentFilters.year = btn.dataset.year;
        applyFilters();
      });
    });

    // Distance
    distanceSelect.addEventListener('change', (e) => {
      currentFilters.distance = e.target.value;
      applyFilters();
    });

    // Location
    locationSelect.addEventListener('change', (e) => {
      currentFilters.location = e.target.value;
      applyFilters();
    });

    // Sort
    sortBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        // Update UI
        sortBtns.forEach((b) => {
          b.classList.remove('text-orange-600', 'dark:text-orange-500');
          b.classList.add('text-gray-500', 'dark:text-gray-400');
        });
        btn.classList.add('text-orange-600', 'dark:text-orange-500');
        btn.classList.remove('text-gray-500', 'dark:text-gray-400');

        currentFilters.sort = btn.dataset.sort;
        applyFilters();
      });
    });

    // Mobile Toggle
    mobileToggle.addEventListener('click', () => {
      filterControls.classList.toggle('hidden');
      filterControls.classList.toggle('flex');
    });
  });
</script>
