---
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<header
  class="border-gray bg-bg flex w-full flex-wrap border-b py-3 text-sm sm:flex-nowrap sm:justify-start"
>
  <nav
    class="mx-auto flex w-full max-w-[85rem] basis-full flex-wrap items-center justify-between px-4"
  >
    <a
      class="flex-none focus:opacity-80 focus:outline-hidden sm:order-1"
      href={translatePath('/')}
    >
      <div class="flex items-center gap-3">
        <img
          src="/rbel-icon.png"
          alt="Randonneurs Belarus"
          class="h-10 w-auto object-contain"
        />
        <div
          class="font-heading text-secondary flex h-10 flex-col justify-center pt-1 text-sm leading-[1] font-black tracking-wider uppercase sm:text-base"
        >
          <span>Беларускія</span>
          <span>Ранданёры</span>
        </div>
      </div>
    </a>
    <div class="flex items-center gap-x-2 sm:order-3">
      <!-- Language Switcher moved here -->
      <div
        class="mr-2 hidden items-center space-x-2 border-r border-gray-600 pr-4 sm:flex"
      >
        <a
          class={lang === 'ru'
            ? 'text-secondary font-bold'
            : 'text-text-muted hover:text-text'}
          href={translatePath('/', 'ru')}>RU</a
        >
        <a
          class={lang === 'be'
            ? 'text-secondary font-bold'
            : 'text-text-muted hover:text-text'}
          href={translatePath('/', 'be')}>BY</a
        >
        <a
          class={lang === 'en'
            ? 'text-secondary font-bold'
            : 'text-text-muted hover:text-text'}
          href={translatePath('/', 'en')}>EN</a
        >
      </div>

      <button
        type="button"
        class="hs-collapse-toggle bg-bg text-text relative flex size-9 items-center justify-center gap-x-2 rounded-lg border border-gray-700 shadow-2xs hover:bg-gray-700 focus:bg-gray-700 focus:outline-hidden disabled:pointer-events-none disabled:opacity-50 sm:hidden"
        id="hs-navbar-alignment-collapse"
        aria-expanded="false"
        aria-controls="hs-navbar-alignment"
        aria-label="Toggle navigation"
        data-hs-collapse="#hs-navbar-alignment"
      >
        <svg
          class="hs-collapse-open:hidden size-4 shrink-0"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="3" x2="21" y1="6" y2="6"></line><line
            x1="3"
            x2="21"
            y1="12"
            y2="12"></line><line x1="3" x2="21" y1="18" y2="18"></line></svg
        >
        <svg
          class="hs-collapse-open:block hidden size-4 shrink-0"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg
        >
        <span class="sr-only">Toggle</span>
      </button>
      <button
        id="theme-toggle"
        type="button"
        class="text-charcoal inline-flex items-center gap-x-2 rounded-full border border-gray-200 bg-white p-2 text-sm font-medium shadow-2xs hover:bg-gray-50 focus:bg-gray-50 focus:outline-hidden disabled:pointer-events-none disabled:opacity-50 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700 dark:focus:bg-gray-700"
        aria-label="Toggle theme"
      >
        <svg
          class="sun hidden h-4 w-4"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path
            d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path
            d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path
            d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path
            d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <svg
          class="moon hidden h-4 w-4"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"
          ></path>
        </svg>
        <svg
          class="system hidden h-4 w-4"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line
            x1="8"
            y1="21"
            x2="16"
            y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line>
        </svg>
      </button>
    </div>

    <style is:global>
      html[data-theme='light'] .sun {
        display: block;
      }
      html[data-theme='dark'] .moon {
        display: block;
      }
      html[data-theme='system'] .system {
        display: block;
      }
    </style>

    <script>
      declare global {
        interface Window {
          applyTheme: (theme: string) => void;
        }
      }
      const themes = ['system', 'light', 'dark'];

      const handleToggleClick = () => {
        const currentTheme =
          document.documentElement.getAttribute('data-theme') || 'system';
        const currentIndex = themes.indexOf(currentTheme);
        const nextTheme = themes[(currentIndex + 1) % themes.length];

        localStorage.setItem('theme', nextTheme);

        if (typeof window.applyTheme === 'function') {
          window.applyTheme(nextTheme);
        } else {
          // Fallback
          const isDark =
            nextTheme === 'dark' ||
            (nextTheme === 'system' &&
              window.matchMedia('(prefers-color-scheme: dark)').matches);
          document.documentElement.classList.toggle('dark', isDark);
          document.documentElement.classList.toggle('light', !isDark);
          document.documentElement.setAttribute('data-theme', nextTheme);
        }
      };

      const setupThemeListener = () => {
        const toggleBtn = document.getElementById('theme-toggle');
        if (toggleBtn) {
          toggleBtn.removeEventListener('click', handleToggleClick);
          toggleBtn.addEventListener('click', handleToggleClick);
        }
      };

      setupThemeListener();
      document.addEventListener('astro:page-load', setupThemeListener);
    </script>
    <div
      id="hs-navbar-alignment"
      class="hs-collapse hidden grow basis-full overflow-hidden transition-all duration-300 sm:order-2 sm:block sm:grow-0 sm:basis-auto"
      aria-labelledby="hs-navbar-alignment-collapse"
    >
      <div
        class="mt-5 flex flex-col gap-5 sm:mt-0 sm:flex-row sm:items-center sm:ps-5"
      >
        <a
          class="hover:text-secondary focus:text-secondary text-text font-medium focus:outline-hidden"
          href={translatePath('/events')}
        >
          {t('nav.events')}
        </a>
        <a
          class="text-text hover:text-secondary focus:text-secondary font-medium focus:outline-hidden"
          href={translatePath('/routes')}
        >
          {t('nav.routes')}
        </a>
        <a
          class="text-text hover:text-secondary focus:text-secondary font-medium focus:outline-hidden"
          href={translatePath('/stats')}
        >
          {t('nav.stats')}
        </a>
        <a
          class="text-text hover:text-secondary focus:text-secondary font-medium focus:outline-hidden"
          href={translatePath('/clubs')}
        >
          {t('nav.clubs')}
        </a>

        <!-- Mobile Language Switcher -->
        <div
          class="mt-2 flex items-center space-x-4 border-t border-gray-200 pt-4 sm:hidden dark:border-gray-700"
        >
          <a
            class={lang === 'ru'
              ? 'text-secondary font-bold'
              : 'text-text-muted'}
            href={translatePath('/', 'ru')}>RU</a
          >
          <a
            class={lang === 'be'
              ? 'text-secondary font-bold'
              : 'text-text-muted'}
            href={translatePath('/', 'be')}>BY</a
          >
          <a
            class={lang === 'en'
              ? 'text-secondary font-bold'
              : 'text-text-muted'}
            href={translatePath('/', 'en')}>EN</a
          >
        </div>
      </div>
    </div>
  </nav>
</header>
