---
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<footer class="bg-bg mx-auto w-full px-4 py-10 sm:px-6 lg:px-8">
  <!-- Grid -->
  <div
    class="mx-auto mb-16 grid max-w-[85rem] grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4"
  >
    <div class="col-span-1 lg:col-span-1">
      <h3 class="text-secondary mb-4 text-sm font-bold uppercase">
        {t('footer.connecting')}
      </h3>
      <p class="text-gray text-sm">
        {t('footer.connecting_desc')}
      </p>
    </div>
    <!-- End Col -->

    <div>
      <h4 class="text-text mb-4 text-sm font-bold uppercase">
        {t('footer.platform')}
      </h4>
      <ul class="space-y-2 text-sm">
        <li>
          <a
            class="hover:text-text text-gray-400"
            href={translatePath('/events')}>{t('footer.upcoming')}</a
          >
        </li>
        <li>
          <a
            class="hover:text-text text-gray-400"
            href={translatePath('/routes')}>{t('footer.route_library')}</a
          >
        </li>
        <li>
          <a
            class="hover:text-text text-gray-400"
            href={translatePath('/stats')}>{t('footer.season_stats')}</a
          >
        </li>
      </ul>
    </div>

    <div>
      <h4 class="text-text mb-4 text-sm font-bold uppercase">
        {t('footer.community')}
      </h4>
      <ul class="space-y-2 text-sm">
        <li>
          <a
            class="hover:text-text text-gray-400"
            href={translatePath('/clubs')}>{t('footer.find_club')}</a
          >
        </li>
        <li>
          <a
            class="hover:text-text text-gray-400"
            href={translatePath('/volunteer')}>{t('footer.volunteer')}</a
          >
        </li>
        <li>
          <a
            class="hover:text-text text-gray-400"
            href={translatePath('/rules')}>{t('footer.rules')}</a
          >
        </li>
      </ul>
    </div>

    <div>
      <h4 class="text-text mb-4 text-sm font-bold uppercase">
        {t('footer.connect')}
      </h4>
      <ul class="space-y-2 text-sm">
        <li>
          <a class="hover:text-text text-gray-400" href="#">Twitter</a>
        </li>
        <li>
          <a class="hover:text-text text-gray-400" href="#">Instagram</a>
        </li>
        <li>
          <a class="hover:text-text text-gray-400" href="#">Strava Club</a>
        </li>
      </ul>
    </div>
  </div>
  <!-- End Grid -->

  <!-- Big Logo -->
  <div
    class="mx-auto mt-8 flex max-w-[85rem] flex-col items-center border-t border-gray-700 pt-8 text-center"
  >
    <div class="mb-4 flex items-center justify-center gap-4 opacity-50">
      <div
        class="font-heading text-gray mt-3 flex h-24 flex-col justify-center text-left text-3xl leading-none font-black tracking-widest uppercase sm:text-4xl md:h-32 md:text-6xl"
      >
        <span>Беларускія Ранданёры</span>
      </div>
    </div>
    <p class="mt-4 text-center text-xs text-gray-500">
      © 2026 Randonneur Platform. All rights reserved.
    </p>
  </div>
</footer>
