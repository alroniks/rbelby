---
---

<section class="bg-white dark:bg-neutral-900 py-16 lg:py-24 overflow-hidden">
  <div class="max-w-[85rem] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Facts and Figures</p>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-white uppercase leading-tight">
        This is not <span class="text-orange-500">just statistics</span>,<br />
        it's <span class="text-orange-500">our history</span> and steps towards<br />
        new discoveries
      </h2>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 relative">
      <!-- Decorative background line/circles could go here -->

      <!-- Stat 1 -->
      <div class="relative flex flex-col items-center justify-center text-center p-8">
        <div class="relative size-40 rounded-full border-4 border-dashed border-gray-300 dark:border-neutral-700 flex items-center justify-center mb-4 animate-[spin_10s_linear_infinite]">
             <svg class="size-full text-gray-200 dark:text-neutral-800" viewBox="0 0 100 100" fill="currentColor">
               <!-- Simple gear representation -->
               <path d="M50 0 L60 10 L70 5 L80 15 L90 10 L95 20 L100 25 L90 35 L95 45 L85 55 L90 65 L80 75 L70 70 L60 80 L50 90 L40 80 L30 70 L20 75 L10 65 L15 55 L5 45 L10 35 L0 25 L5 20 L10 10 L20 15 L30 5 L40 10 Z" />
             </svg>
        </div>
        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-full mt-8">
            <span class="block text-4xl font-bold text-gray-800 dark:text-white">1,248</span>
            <span class="block text-sm text-gray-500 dark:text-gray-400">active riders</span>
        </div>
      </div>

      <!-- Stat 2 -->
      <div class="relative flex flex-col items-center justify-center text-center p-8">
        <div class="relative size-40 rounded-full border-4 border-dashed border-gray-300 dark:border-neutral-700 flex items-center justify-center mb-4 animate-[spin_12s_linear_infinite_reverse]">
             <svg class="size-full text-gray-200 dark:text-neutral-800" viewBox="0 0 100 100" fill="currentColor">
               <path d="M50 0 L60 10 L70 5 L80 15 L90 10 L95 20 L100 25 L90 35 L95 45 L85 55 L90 65 L80 75 L70 70 L60 80 L50 90 L40 80 L30 70 L20 75 L10 65 L15 55 L5 45 L10 35 L0 25 L5 20 L10 10 L20 15 L30 5 L40 10 Z" />
             </svg>
        </div>
        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-full mt-8">
            <span class="block text-4xl font-bold text-gray-800 dark:text-white">45</span>
            <span class="block text-sm text-gray-500 dark:text-gray-400">total events</span>
        </div>
      </div>

      <!-- Stat 3 -->
      <div class="relative flex flex-col items-center justify-center text-center p-8">
        <div class="relative size-40 rounded-full border-4 border-dashed border-gray-300 dark:border-neutral-700 flex items-center justify-center mb-4 animate-[spin_14s_linear_infinite]">
             <svg class="size-full text-gray-200 dark:text-neutral-800" viewBox="0 0 100 100" fill="currentColor">
               <path d="M50 0 L60 10 L70 5 L80 15 L90 10 L95 20 L100 25 L90 35 L95 45 L85 55 L90 65 L80 75 L70 70 L60 80 L50 90 L40 80 L30 70 L20 75 L10 65 L15 55 L5 45 L10 35 L0 25 L5 20 L10 10 L20 15 L30 5 L40 10 Z" />
             </svg>
        </div>
        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-full mt-8">
            <span class="block text-4xl font-bold text-gray-800 dark:text-white">342k</span>
            <span class="block text-sm text-gray-500 dark:text-gray-400">km ridden</span>
        </div>
      </div>
    </div>
  </div>
</section>
