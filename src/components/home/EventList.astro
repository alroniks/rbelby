---
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const today = new Date();

// Filter and sort events
const upcomingEvents = allEvents
  .filter(event => event.data.date >= today)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime())
  .slice(0, 8);

function getTimeLimit(distance: number) {
  if (distance >= 1200) return "90h 00m";
  if (distance >= 1000) return "75h 00m";
  if (distance >= 600) return "40h 00m";
  if (distance >= 400) return "27h 00m";
  if (distance >= 300) return "20h 00m";
  if (distance >= 200) return "13h 30m";
  return "N/A";
}

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { month: 'short', day: 'numeric' });
}
---

<section class="bg-white dark:bg-neutral-900 py-16 lg:py-24">
  <div class="max-w-[85rem] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Upcoming Brevets</p>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-white uppercase leading-tight mb-6">
        Register for <span class="text-orange-500">Official Events</span><br />
        Happening <span class="text-orange-500">Soon Near You</span>
      </h2>
      <div class="flex justify-center">
        <a href="/events" class="py-3 px-6 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-full border border-transparent bg-orange-500 text-white hover:bg-orange-600 disabled:opacity-50 disabled:pointer-events-none">
            View all
            <svg class="shrink-0 size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {upcomingEvents.map(event => (
        <a href={`/events/${event.id}`} class="group block relative overflow-hidden rounded-xl bg-neutral-800 hover:shadow-xl transition-all duration-300">
          <!-- Image -->
          <div class="aspect-w-16 aspect-h-12 overflow-hidden">
            <img
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              src={`https://images.unsplash.com/photo-1559166631-ef208440c75a?q=80&w=600&auto=format&fit=crop`}
              alt={event.data.name}
            />
          </div>

          <!-- Content -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent p-6 flex flex-col justify-end">
             <div class="mb-1">
                 <h3 class="text-lg font-bold text-white uppercase truncate">{event.data.name}</h3>
             </div>

             <div class="flex items-end justify-between border-t border-white/20 pt-3">
                <div>
                     <span class="block text-4xl font-bold text-orange-500 leading-none">{event.data.distance}</span>
                </div>
                <div class="text-right">
                    <span class="block text-gray-300 text-xs uppercase">Date</span>
                    <span class="block text-white font-semibold leading-none mb-1">{formatDate(event.data.date)}</span>
                    <span class="block text-orange-400 text-xs">{getTimeLimit(event.data.distance)}</span>
                </div>
             </div>
          </div>
        </a>
      ))}
      {upcomingEvents.length === 0 && (
          <div class="col-span-4 text-center text-gray-400 py-12">
              No upcoming events found.
          </div>
      )}
    </div>
  </div>
</section>
