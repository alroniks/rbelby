---
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const today = new Date();

// Filter and sort events
const upcomingEvents = allEvents
  .filter((event) => event.data.date >= today)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime())
  .slice(0, 8);

function getTimeLimit(distance: number) {
  if (distance >= 1200) return '90h 00m';
  if (distance >= 1000) return '75h 00m';
  if (distance >= 600) return '40h 00m';
  if (distance >= 400) return '27h 00m';
  if (distance >= 300) return '20h 00m';
  if (distance >= 200) return '13h 30m';
  return 'N/A';
}

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', { month: 'short', day: 'numeric' });
}
---

<section class="bg-white py-16 lg:py-24 dark:bg-neutral-900">
  <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <p class="mb-2 text-xs font-bold tracking-widest text-gray-500 uppercase">
        Upcoming Brevets
      </p>
      <h2
        class="mb-6 text-3xl leading-tight font-bold text-gray-800 uppercase md:text-4xl dark:text-white"
      >
        Register for <span class="text-orange-500">Official Events</span><br />
        Happening <span class="text-orange-500">Soon Near You</span>
      </h2>
      <div class="flex justify-center">
        <a
          href="/events"
          class="inline-flex items-center justify-center gap-x-2 rounded-full border border-transparent bg-orange-500 px-6 py-3 text-sm font-semibold text-white hover:bg-orange-600 disabled:pointer-events-none disabled:opacity-50"
        >
          View all
          <svg
            class="size-4 shrink-0"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
          >
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        upcomingEvents.map((event) => (
          <a
            href={`/events/${event.id}`}
            class="group relative block overflow-hidden rounded-xl bg-neutral-800 transition-all duration-300 hover:shadow-xl"
          >
            {/* Image */}
            <div class="aspect-w-16 aspect-h-12 overflow-hidden">
              <img
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                src={`https://images.unsplash.com/photo-1559166631-ef208440c75a?q=80&w=600&auto=format&fit=crop`}
                alt={event.data.name}
              />
            </div>

            {/* Content */}
            <div class="absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-black/90 via-black/40 to-transparent p-6">
              <div class="mb-1">
                <h3 class="truncate text-lg font-bold text-white uppercase">
                  {event.data.name}
                </h3>
              </div>

              <div class="flex items-end justify-between border-t border-white/20 pt-3">
                <div>
                  <span class="block text-4xl leading-none font-bold text-orange-500">
                    {event.data.distance}
                  </span>
                </div>
                <div class="text-right">
                  <span class="block text-xs text-gray-300 uppercase">
                    Date
                  </span>
                  <span class="mb-1 block leading-none font-semibold text-white">
                    {formatDate(event.data.date)}
                  </span>
                  <span class="block text-xs text-orange-400">
                    {getTimeLimit(event.data.distance)}
                  </span>
                </div>
              </div>
            </div>
          </a>
        ))
      }
      {
        upcomingEvents.length === 0 && (
          <div class="col-span-4 py-12 text-center text-gray-400">
            No upcoming events found.
          </div>
        )
      }
    </div>
  </div>
</section>
