---
const faqs = [
  {
    question: 'What is a brevet?',
    answer:
      'A brevet is a long-distance cycling event within prescribed time limits in a non-competitive nature. It is not a race.',
  },
  {
    question: 'Who can participate in brevets?',
    answer:
      'Brevets are open to any cyclist who is physically capable of completing the distance. Membership in a club may be required for some events.',
  },
  {
    question: 'Do I need to bring my own bike?',
    answer:
      'Yes, you must provide your own bicycle. It must be human-powered and road-worthy. Ebikes are generally not allowed in official ACP brevets.',
  },
  {
    question: 'What happens if the event is canceled due to bad weather?',
    answer:
      'Events are rarely canceled due to weather unless conditions are dangerous. Check the specific event rules for cancellation policies.',
  },
  {
    question: 'Are there age restrictions for participation?',
    answer:
      'Generally, participants must be at least 18 years old. Minors may participate with parental consent in some shorter events.',
  },
  {
    question: 'How do I register for an event?',
    answer:
      'Registration is handled through this platform. Go to the event page and follow the registration instructions.',
  },
];
---

<section class="bg-surface py-16 lg:py-24 bg-surface">
  <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-8">
      <!-- Text Content -->
      <div class="lg:col-span-5">
        <div class="mb-8">
          <p
            class="mb-2 text-xs font-bold tracking-widest text-text-muted uppercase"
          >
            Do you have any questions?
          </p>
          <h2
            class="text-3xl leading-tight font-bold text-text uppercase md:text-4xl text-text"
          >
            Learn how to <span class="text-primary">participate</span><br />
            in and prepare for a<br />
            cycling <span class="text-primary">adventure</span>
          </h2>
        </div>
        <p class="mb-8 text-text-muted text-text-muted">
          Find answers to common questions about rules, equipment, and
          registration.
        </p>
        <a
          href="/faq"
          class="inline-flex items-center justify-center gap-x-2 rounded-full border border-gray bg-primary px-6 py-3 text-sm font-semibold text-text hover:opacity-90 disabled:pointer-events-none disabled:opacity-50"
        >
          View library
          <svg
            class="size-4 shrink-0"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
          >
        </a>
      </div>

      <!-- Accordion -->
      <div class="lg:col-span-7">
        <div class="hs-accordion-group">
          {
            faqs.map((faq, index) => (
              <div
                class="hs-accordion mb-3 rounded-xl border border-gray  border-gray bg-bg"
                id={`hs-basic-heading-${index}`}
              >
                <button
                  class="hs-accordion-toggle group inline-flex w-full items-center justify-between gap-x-3 rounded-xl p-6 pb-3 text-start font-semibold text-text transition hover:text-text-muted focus:text-text-muted focus:outline-none md:text-lg text-text hover:text-primary focus:text-primary"
                  aria-expanded="false"
                  aria-controls={`hs-basic-collapse-${index}`}
                >
                  {faq.question}
                  <svg
                    class="hs-accordion-active:hidden block size-5 shrink-0 text-text-muted group-hover:text-text-muted text-text-muted"
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <path d="M12 5v14" />
                      <path d="M5 12h14" />
                    </>
                  </svg>
                  <svg
                    class="hs-accordion-active:block hidden size-5 shrink-0 text-text-muted group-hover:text-text-muted text-text-muted"
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M5 12h14" />
                  </svg>
                </button>
                <div
                  id={`hs-basic-collapse-${index}`}
                  class="hs-accordion-content hidden w-full overflow-hidden transition-[height] duration-300"
                  aria-labelledby={`hs-basic-heading-${index}`}
                >
                  <div class="px-6 pb-6">
                    <p class="text-text-muted text-text-muted">
                      {faq.answer}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
