---
const faqs = [
  {
    question: "What is a brevet?",
    answer: "A brevet is a long-distance cycling event within prescribed time limits in a non-competitive nature. It is not a race."
  },
  {
    question: "Who can participate in brevets?",
    answer: "Brevets are open to any cyclist who is physically capable of completing the distance. Membership in a club may be required for some events."
  },
  {
    question: "Do I need to bring my own bike?",
    answer: "Yes, you must provide your own bicycle. It must be human-powered and road-worthy. Ebikes are generally not allowed in official ACP brevets."
  },
  {
    question: "What happens if the event is canceled due to bad weather?",
    answer: "Events are rarely canceled due to weather unless conditions are dangerous. Check the specific event rules for cancellation policies."
  },
  {
    question: "Are there age restrictions for participation?",
    answer: "Generally, participants must be at least 18 years old. Minors may participate with parental consent in some shorter events."
  },
  {
    question: "How do I register for an event?",
    answer: "Registration is handled through this platform. Go to the event page and follow the registration instructions."
  }
];
---

<section class="bg-gray-50 dark:bg-neutral-800 py-16 lg:py-24">
  <div class="max-w-[85rem] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-8">
      <!-- Text Content -->
      <div class="lg:col-span-5">
        <div class="mb-8">
            <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Do you have any questions?</p>
            <h2 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-white uppercase leading-tight">
                Learn how to <span class="text-orange-500">participate</span><br />
                in and prepare for a<br />
                cycling <span class="text-orange-500">adventure</span>
            </h2>
        </div>
        <p class="text-gray-600 dark:text-gray-400 mb-8">
            Find answers to common questions about rules, equipment, and registration.
        </p>
        <a href="/faq" class="py-3 px-6 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-full border border-transparent bg-orange-500 text-white hover:bg-orange-600 disabled:opacity-50 disabled:pointer-events-none">
            View library
            <svg class="shrink-0 size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>

      <!-- Accordion -->
      <div class="lg:col-span-7">
        <div class="hs-accordion-group">
          {faqs.map((faq, index) => (
            <div class="hs-accordion bg-white dark:bg-neutral-900 border border-transparent dark:border-neutral-700 rounded-xl mb-3" id={`hs-basic-heading-${index}`}>
              <button class="hs-accordion-toggle group pb-3 inline-flex items-center justify-between gap-x-3 w-full md:text-lg font-semibold text-start text-gray-800 rounded-xl transition hover:text-gray-500 focus:outline-none focus:text-gray-500 dark:text-neutral-200 dark:hover:text-neutral-400 dark:focus:text-neutral-400 p-6" aria-expanded="false" aria-controls={`hs-basic-collapse-${index}`}>
                {faq.question}
                <svg class="hs-accordion-active:hidden block shrink-0 size-5 text-gray-600 group-hover:text-gray-500 dark:text-neutral-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                <svg class="hs-accordion-active:block hidden shrink-0 size-5 text-gray-600 group-hover:text-gray-500 dark:text-neutral-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>
              </button>
              <div id={`hs-basic-collapse-${index}`} class="hs-accordion-content hidden w-full overflow-hidden transition-[height] duration-300" aria-labelledby={`hs-basic-heading-${index}`}>
                <div class="pb-6 px-6">
                  <p class="text-gray-600 dark:text-neutral-400">
                    {faq.answer}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
