---
const routes = [
  {
    name: "Tsnyansky Forest Travel",
    distance: "25 km",
    image: "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?q=80&w=600&auto=format&fit=crop"
  },
  {
    name: "Endless Gravel",
    distance: "165 km",
    image: "https://images.unsplash.com/photo-1596706057077-8ae3676878b2?q=80&w=600&auto=format&fit=crop"
  },
  {
    name: "East Classic",
    distance: "55 km",
    image: "https://images.unsplash.com/photo-1541625602330-2277a4c46182?q=80&w=600&auto=format&fit=crop"
  },
  {
    name: "Croissant Ride",
    distance: "220 km",
    image: "https://images.unsplash.com/photo-1616963248328-6b7aec5749a5?q=80&w=600&auto=format&fit=crop"
  }
];
---

<section class="bg-white dark:bg-neutral-900 py-16 lg:py-24">
  <div class="max-w-[85rem] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Popular Routes</p>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-white uppercase leading-tight mb-6">
        Explore <span class="text-orange-500">Legendary Courses</span><br />
        and Plan Your <span class="text-orange-500">Own Adventure</span>
      </h2>
      <div class="flex justify-center">
        <a href="/routes" class="py-3 px-6 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-full border border-transparent bg-orange-500 text-white hover:bg-orange-600 disabled:opacity-50 disabled:pointer-events-none">
            View library
            <svg class="shrink-0 size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {routes.map(route => (
        <a href="#" class="group block relative overflow-hidden rounded-xl h-[400px]">
          <img
            src={route.image}
            alt={route.name}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>

          <div class="absolute bottom-0 left-0 p-6 w-full">
            <h3 class="text-xl font-bold text-white uppercase mb-1">{route.name}</h3>
            <p class="text-orange-400 font-semibold">{route.distance}</p>
            <div class="mt-4 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
                <span class="inline-flex items-center gap-x-2 text-sm text-white font-medium">
                    Explore route
                    <svg class="shrink-0 size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m12 8 4 4-4 4"/><path d="M8 12h8"/></svg>
                </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
