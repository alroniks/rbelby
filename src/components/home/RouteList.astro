---
const routes = [
  {
    name: 'Tsnyansky Forest Travel',
    distance: '25 km',
    image:
      'https://images.unsplash.com/photo-1441974231531-c6227db76b6e?q=80&w=600&auto=format&fit=crop',
  },
  {
    name: 'Endless Gravel',
    distance: '165 km',
    image:
      'https://images.unsplash.com/photo-1596706057077-8ae3676878b2?q=80&w=600&auto=format&fit=crop',
  },
  {
    name: 'East Classic',
    distance: '55 km',
    image:
      'https://images.unsplash.com/photo-1541625602330-2277a4c46182?q=80&w=600&auto=format&fit=crop',
  },
  {
    name: 'Croissant Ride',
    distance: '220 km',
    image:
      'https://images.unsplash.com/photo-1616963248328-6b7aec5749a5?q=80&w=600&auto=format&fit=crop',
  },
];
---

<section class="bg-white py-16 lg:py-24 dark:bg-neutral-900">
  <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <p class="mb-2 text-xs font-bold tracking-widest text-gray-500 uppercase">
        Popular Routes
      </p>
      <h2
        class="mb-6 text-3xl leading-tight font-bold text-gray-800 uppercase md:text-4xl dark:text-white"
      >
        Explore <span class="text-orange-500">Legendary Courses</span><br />
        and Plan Your <span class="text-orange-500">Own Adventure</span>
      </h2>
      <div class="flex justify-center">
        <a
          href="/routes"
          class="inline-flex items-center justify-center gap-x-2 rounded-full border border-transparent bg-orange-500 px-6 py-3 text-sm font-semibold text-white hover:bg-orange-600 disabled:pointer-events-none disabled:opacity-50"
        >
          View library
          <svg
            class="size-4 shrink-0"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
          >
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        routes.map((route) => (
          <a
            href="#"
            class="group relative block h-[400px] overflow-hidden rounded-xl"
          >
            <img
              src={route.image}
              alt={route.name}
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent" />

            <div class="absolute bottom-0 left-0 w-full p-6">
              <h3 class="mb-1 text-xl font-bold text-white uppercase">
                {route.name}
              </h3>
              <p class="font-semibold text-orange-400">{route.distance}</p>
              <div class="mt-4 translate-y-4 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
                <span class="inline-flex items-center gap-x-2 text-sm font-medium text-white">
                  Explore route
                  <svg
                    class="size-4 shrink-0"
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <circle cx="12" cy="12" r="10" />
                      <path d="m12 8 4 4-4 4" />
                      <path d="M8 12h8" />
                    </>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
