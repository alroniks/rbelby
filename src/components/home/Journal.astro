---
const articles = [
  {
    title: "Round the Minsk Trip. Belarus Randonneurs club",
    date: "06/08/2025",
    distance: "Brevet 300 km",
    image: "https://images.unsplash.com/photo-1517649763962-0c623066013b?q=80&w=600&auto=format&fit=crop"
  },
  {
    title: "Lighthouse. Novopolotsk. The Vanda Club",
    date: "25/08/2025",
    distance: "Brevet 300 km",
    image: "https://images.unsplash.com/photo-1541625602330-2277a4c46182?q=80&w=600&auto=format&fit=crop"
  },
  {
    title: "Oshmyanskaya path",
    date: "16/09/2025",
    distance: "Brevet 400 km",
    image: "https://images.unsplash.com/photo-1534158914592-062992bbe900?q=80&w=600&auto=format&fit=crop"
  }
];
---

<section class="bg-white dark:bg-neutral-900 py-16 lg:py-24">
  <div class="max-w-[85rem] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Journal</p>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-white uppercase leading-tight mb-6">
        Stay updated <span class="text-orange-500">with our latest news</span>,<br />
        featuring exching travel tips,<br />
        guides and <span class="text-orange-500">brevet's diaries</span>
      </h2>
      <div class="flex justify-center">
        <a href="/blog" class="py-3 px-6 inline-flex justify-center items-center gap-x-2 text-sm font-semibold rounded-full border border-transparent bg-orange-500 text-white hover:bg-orange-600 disabled:opacity-50 disabled:pointer-events-none">
            View all
            <svg class="shrink-0 size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {articles.map(article => (
        <a href="#" class="group block relative overflow-hidden rounded-xl h-[300px]">
          <img
            src={article.image}
            alt={article.title}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>

          <div class="absolute top-0 left-0 p-4">
              <span class="inline-block py-1 px-2 rounded-sm bg-neutral-800/80 text-white text-xs backdrop-blur-sm">{article.date}</span>
          </div>

          <div class="absolute bottom-0 left-0 p-6 w-full">
            <span class="text-orange-400 text-xs font-bold uppercase mb-1 block">{article.distance}</span>
            <h3 class="text-lg font-bold text-white uppercase leading-snug">{article.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
