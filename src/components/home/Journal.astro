---
const articles = [
  {
    title: 'Round the Minsk Trip. Belarus Randonneurs club',
    date: '06/08/2025',
    distance: 'Brevet 300 km',
    image:
      'https://images.unsplash.com/photo-1517649763962-0c623066013b?q=80&w=600&auto=format&fit=crop',
  },
  {
    title: 'Lighthouse. Novopolotsk. The Vanda Club',
    date: '25/08/2025',
    distance: 'Brevet 300 km',
    image:
      'https://images.unsplash.com/photo-1541625602330-2277a4c46182?q=80&w=600&auto=format&fit=crop',
  },
  {
    title: 'Oshmyanskaya path',
    date: '16/09/2025',
    distance: 'Brevet 400 km',
    image:
      'https://images.unsplash.com/photo-1534158914592-062992bbe900?q=80&w=600&auto=format&fit=crop',
  },
];
---

<section class="bg-white py-16 lg:py-24 dark:bg-neutral-900">
  <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <p class="mb-2 text-xs font-bold tracking-widest text-gray-500 uppercase">
        Journal
      </p>
      <h2
        class="mb-6 text-3xl leading-tight font-bold text-gray-800 uppercase md:text-4xl dark:text-white"
      >
        Stay updated <span class="text-orange-500">with our latest news</span
        >,<br />
        featuring exching travel tips,<br />
        guides and <span class="text-orange-500">brevet's diaries</span>
      </h2>
      <div class="flex justify-center">
        <a
          href="/blog"
          class="inline-flex items-center justify-center gap-x-2 rounded-full border border-transparent bg-orange-500 px-6 py-3 text-sm font-semibold text-white hover:bg-orange-600 disabled:pointer-events-none disabled:opacity-50"
        >
          View all
          <svg
            class="size-4 shrink-0"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
          >
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {
        articles.map((article) => (
          <a
            href="#"
            class="group relative block h-[300px] overflow-hidden rounded-xl"
          >
            <img
              src={article.image}
              alt={article.title}
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent" />

            <div class="absolute top-0 left-0 p-4">
              <span class="inline-block rounded-sm bg-neutral-800/80 px-2 py-1 text-xs text-white backdrop-blur-sm">
                {article.date}
              </span>
            </div>

            <div class="absolute bottom-0 left-0 w-full p-6">
              <span class="mb-1 block text-xs font-bold text-orange-400 uppercase">
                {article.distance}
              </span>
              <h3 class="text-lg leading-snug font-bold text-white uppercase">
                {article.title}
              </h3>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
