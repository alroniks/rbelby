---

---

<section
  class="relative flex min-h-[600px] items-center overflow-hidden bg-neutral-900"
>
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1541625602330-2277a4c46182?q=80&w=2070&auto=format&fit=crop"
      alt="Cyclist"
      class="h-full w-full object-cover opacity-50"
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-neutral-900/10 via-neutral-900/60 to-neutral-900"
    >
    </div>
  </div>

  <div
    class="relative z-10 mx-auto max-w-[85rem] px-4 text-center sm:px-6 lg:px-8"
  >
    <h1
      class="mb-6 block text-4xl leading-tight font-bold tracking-tight text-white uppercase sm:text-5xl md:text-6xl lg:text-7xl"
    >
      Discover <span class="text-orange-500">Your Next</span><br />
      Endurance <span class="text-orange-500">Challenge</span>
    </h1>

    <p class="mx-auto mt-3 mb-10 max-w-2xl text-lg text-gray-300">
      The premier platform for finding official brevets, exploring certified
      routes, and connecting with the randonneuring community
    </p>

    <div class="flex flex-col justify-center gap-4 sm:flex-row">
      <a
        class="inline-flex items-center justify-center gap-x-2 rounded-full border border-transparent bg-orange-500 px-6 py-3 text-sm font-semibold text-white hover:bg-orange-600 disabled:pointer-events-none disabled:opacity-50"
        href="/events"
      >
        Find events
        <svg
          class="size-4 shrink-0"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
        >
      </a>
      <a
        class="inline-flex items-center justify-center gap-x-2 rounded-full border border-white px-6 py-3 text-sm font-semibold text-white hover:bg-white/10 disabled:pointer-events-none disabled:opacity-50"
        href="/routes"
      >
        Explore routes
        <svg
          class="size-4 shrink-0"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
        >
      </a>
    </div>
  </div>
</section>
