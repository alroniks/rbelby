          ]
        },
        {
          "type": "frame",
          "id": "WB1Uy",
          "name": "artBody",
          "width": "fill_container",
          "layout": "vertical",
          "padding": [
            0,
            64,
            80,
            64
          ],
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "id": "fqHvY",
              "name": "artContent",
              "width": 800,
              "layout": "vertical",
              "gap": 32,
              "children": [
                {
                  "type": "text",
                  "id": "y9bqhJ",
                  "fill": "#0F284B",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "When the weather turns sour halfway through a Super Randonneur series, your equipment choices matter more than ever. I learned this the hard way during my first 600km qualifier. The forecast called for light showers; reality delivered a torrential downpour that lasted for 14 straight hours.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "VwWcq",
                  "fill": "#0F284B",
                  "content": "The Right Jacket",
                  "fontFamily": "Oswald",
                  "fontSize": 32,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "M2LMTy",
                  "fill": "#0F284B",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "A good rain jacket is the cornerstone of your wet-weather kit. It needs to strike the impossible balance between waterproofing and breathability. Gore-Tex Shakedry was the gold standard, but newer alternatives are closing the gap.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "uYEMh",
                  "name": "screamer",
                  "width": "fill_container",
                  "fill": "#FFD100",
                  "cornerRadius": 12,
                  "gap": 24,
                  "padding": 32,
                  "children": [
                    {
                      "type": "text",
                      "id": "fM5Q9",
                      "content": "💡",
                      "fontFamily": "Inter",
                      "fontSize": 24,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "W2B9Do",
                      "fill": "#0F284B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "PRO TIP: Always pack your rain gear in a waterproof dry bag inside your saddlebag. A wet jacket at the start of a cold night is a recipe for hypothermia.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 18,
                      "fontWeight": "600"
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "ejAPH",
                  "fill": "#0F284B",
                  "content": "Layering strategy",
                  "fontFamily": "Oswald",
                  "fontSize": 32,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "ZUh3N",
                  "fill": "#0F284B",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Merino wool base layers retain their insulating properties even when wet. Combine this with a thermal mid-layer and your rain shell, and you create a micro-climate that will sustain you through the coldest descents.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "R38KJA",
                  "name": "quote",
                  "width": "fill_container",
                  "stroke": {
                    "thickness": {
                      "left": 4
                    },
                    "fill": "#054EA4"
                  },
                  "padding": [
                    24,
                    0,
                    24,
                    32
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "k1AMl0",
                      "fill": "#0F284B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "\"There is no such thing as bad weather, only bad clothing. And maybe bad tire choices.\"",
                      "lineHeight": 1.3,
                      "fontFamily": "Oswald",
                      "fontSize": 32,
                      "fontWeight": "600",
                      "fontStyle": "italic"
                    }
