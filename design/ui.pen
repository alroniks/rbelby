            64
          ],
          "children": [
            {
              "type": "frame",
              "id": "N4eLQ",
              "name": "cLeft",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 40,
              "children": [
                {
                  "type": "text",
                  "id": "W9vRuS",
                  "fill": "#0F284B",
                  "content": "About the Club",
                  "fontFamily": "Oswald",
                  "fontSize": 32,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "wKyih",
                  "fill": "#0F284B",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "The Minsk Randonneurs is the oldest and largest ultra-distance cycling club in the capital. We host regular weekend training rides, organize official ACP brevets, and foster a welcoming community for cyclists looking to push their endurance limits. Our routes span the entire Minsk region, featuring a mix of smooth tarmac, challenging gravel, and historical landmarks.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "H9XD5",
                  "name": "cFacts",
                  "width": "fill_container",
                  "height": 200,
                  "gap": 24,
                  "children": [
                    {
                      "type": "frame",
                      "id": "NNh6a",
                      "name": "cf1",
