                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 32,
                  "children": [
                    {
                      "type": "text",
                      "id": "u2ikws",
                      "fill": "#0F284B",
                      "content": "THE EARLY DAYS",
                      "fontFamily": "Oswald",
                      "fontSize": 32,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "cxZFi",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Before GPS head units and ultra-light bikepacking gear, completing a 200km brevet required a paper cue sheet, a reliable dynamo, and immense grit. Our first official brevet saw only 8 finishers, battling headwinds and gravel roads. It wasn't about speed; it was about survival and camaraderie.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "iWAII",
                      "name": "screamer",
                      "width": "fill_container",
                      "fill": "#F8F5EE",
                      "stroke": {
