              "fill": "#0B1120",
              "textGrowth": "fixed-width",
              "width": 1000,
              "content": "Surviving the 600km in the Rain:\nA Comprehensive Gear Guide",
              "lineHeight": 1.1,
              "textAlign": "center",
              "fontFamily": "Overpass",
