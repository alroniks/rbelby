                        },
                        "fill": "#054EA4"
                      },
                      "layout": "vertical",
                      "gap": 16,
                      "padding": 32,
                      "children": [
                        {
                          "type": "text",
                          "id": "F6dkEy",
                          "fill": "#0F284B",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "\"We didn't ride to win. We rode to prove that the human body can outlast the setting sun.\"",
                          "lineHeight": 1.3,
                          "fontFamily": "Oswald",
                          "fontSize": 24,
                          "fontWeight": "600",
                          "fontStyle": "italic"
