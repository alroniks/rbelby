          "children": [
            {
              "type": "frame",
              "id": "yfeCR",
              "name": "vision",
              "width": 1000,
              "layout": "vertical",
              "gap": 32,
              "children": [
                {
                  "type": "text",
                  "id": "ekwKc",
                  "fill": "#0B1120",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "CYCLING IS NOT JUST ABOUT THE BIKE. IT'S ABOUT THE JOURNEY, THE PEOPLE, AND THE RELENTLESS WILL TO KEEP PEDALING.",
                  "lineHeight": 1.1,
                  "fontFamily": "Overpass",
                  "fontSize": 48,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "FCQYp",
                  "fill": "#64748B",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Founded in 2010, Randonneurs Belarus started with a simple idea: to bring the rich French tradition of Audax Club Parisien to the sprawling, beautiful roads of our homeland. What began with a handful of enthusiasts has grown into a nationwide movement.",
                  "lineHeight": 1.6,
                  "fontFamily": "Montserrat",
                  "fontSize": 20,
                  "fontWeight": "normal"
                }
              ]
            },
