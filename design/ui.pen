            {
              "type": "frame",
              "id": "i3hgT",
              "name": "history",
              "width": 1000,
              "gap": 64,
              "children": [
                {
                  "type": "frame",
                  "id": "J6k3N",
                  "name": "hLeft",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 32,
                  "children": [
                    {
                      "type": "text",
                      "id": "u2ikws",
                      "fill": "#0B1120",
                      "content": "THE EARLY DAYS",
                      "fontFamily": "Overpass",
                      "fontSize": 32,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "cxZFi",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Before GPS head units and ultra-light bikepacking gear, completing a 200km brevet required a paper cue sheet, a reliable dynamo, and immense grit. Our first official brevet saw only 8 finishers, battling headwinds and gravel roads. It wasn't about speed; it was about survival and camaraderie.",
                      "lineHeight": 1.6,
                      "fontFamily": "Montserrat",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "iWAII",
                      "name": "screamer",
                      "width": "fill_container",
                      "fill": "#F8F5EE",
                      "stroke": {
                        "thickness": {
                          "left": 4
                        },
                        "fill": "#054EA4"
                      },
                      "layout": "vertical",
                      "gap": 16,
                      "padding": 32,
                      "children": [
                        {
                          "type": "text",
                          "id": "F6dkEy",
                          "fill": "#0B1120",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "\"We didn't ride to win. We rode to prove that the human body can outlast the setting sun.\"",
                          "lineHeight": 1.3,
                          "fontFamily": "Overpass",
                          "fontSize": 24,
                          "fontWeight": "600",
                          "fontStyle": "italic"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "PHiCI",
                  "name": "hRight",
                  "width": 400,
                  "height": 400,
                  "layout": "none",
                  "children": [
                    {
                      "type": "frame",
                      "id": "WYvvl",
                      "x": 0,
                      "y": 0,
                      "name": "imgH",
                      "width": 400,
