                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "OFFICIAL ACP REGULATIONS",
                      "fontFamily": "Overpass",
                      "fontSize": 32,
                      "fontWeight": "700"
                    },
                    {
                      "type": "frame",
                      "id": "o27MNn",
                      "name": "ar1",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 16,
                      "children": [
                        {
                          "type": "text",
                          "id": "s0sJtn",
                          "fill": "#0B1120",
                          "content": "Article 1: Qualification",
                          "fontFamily": "Overpass",
                          "fontSize": 24,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "vkezJ",
                          "fill": "#64748B",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "These brevets are open to any amateur cyclist regardless of his or her cycling affiliations, covered by insurance. Any rider under the age of 18 must have consent of his or her parent or legal guardian.",
                          "lineHeight": 1.5,
                          "fontFamily": "Montserrat",
                          "fontSize": 16,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "y4WIi",
                      "name": "ar2",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 16,
                      "children": [
                        {
                          "type": "text",
                          "id": "fQaFS",
                          "fill": "#0B1120",
                          "content": "Article 2: Route Deviations",
                          "fontFamily": "Overpass",
                          "fontSize": 24,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "A9RFU",
                          "fill": "#64748B",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Each rider must stay on the route. If a rider leaves the route, they must return to the route at the same point prior to continuing, ie. no shortcuts or detours from the route, unless specified by the organizer.",
                          "lineHeight": 1.5,
                          "fontFamily": "Montserrat",
                          "fontSize": 16,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "PFiCC",
                      "name": "ar3",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 16,
                      "children": [
                        {
                          "type": "text",
                          "id": "AHnj9",
                          "fill": "#0B1120",
                          "content": "Article 3: Homologation",
                          "fontFamily": "Overpass",
                          "fontSize": 24,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "sVg3R",
                          "fill": "#64748B",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "At the finish, the rider must sign his brevet card and return it to the organizer. The brevet card will be returned to the rider after the brevet has been verified and a homologation number issued.",
                          "lineHeight": 1.5,
                          "fontFamily": "Montserrat",
                          "fontSize": 16,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
