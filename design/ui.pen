          }
        },
        {
          "type": "frame",
          "id": "iLJL8",
          "name": "faqContent",
          "width": "fill_container",
          "gap": 64,
          "padding": 64,
          "children": [
            {
              "type": "frame",
              "id": "H5zCh",
              "name": "newLeft",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 48,
              "children": [
                {
                  "type": "text",
                  "id": "g2z29j",
                  "fill": "#0B1120",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Equipment & Gear",
                  "fontFamily": "Overpass",
                  "fontSize": 32,
                  "fontWeight": "700"
                },
                {
                  "type": "frame",
                  "id": "DuedJ",
                  "name": "faq1",
                  "width": "fill_container",
                  "fill": "#F8F5EE",
                  "cornerRadius": [
                    0,
                    32,
                    0,
                    0
                  ],
                  "layout": "vertical",
                  "gap": 16,
                  "padding": 32,
                  "children": [
                    {
                      "type": "text",
                      "id": "d4vftI",
                      "fill": "#0B1120",
                      "content": "Q: Do I need a special bike?",
                      "fontFamily": "Overpass",
                      "fontSize": 20,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "NTOSa",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "A: No, any human-powered vehicle is allowed as long as it is propelled solely by the rider.",
                      "lineHeight": 1.5,
                      "fontFamily": "Montserrat",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "TmQOD",
                  "name": "faq2",
                  "width": "fill_container",
                  "fill": "#F0F4F8",
                  "cornerRadius": [
                    0,
                    32,
                    0,
                    0
                  ],
                  "layout": "vertical",
                  "gap": 16,
                  "padding": 32,
                  "children": [
                    {
                      "type": "text",
                      "id": "SuZ7O",
                      "fill": "#0B1120",
                      "content": "Q: What kind of lights are required?",
                      "fontFamily": "Overpass",
                      "fontSize": 20,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "cQAWA",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "A: You must have a front white light and a rear red light securely attached to the bike. Both must be turned on during night riding and low visibility. Spare lights are highly recommended.",
                      "lineHeight": 1.5,
                      "fontFamily": "Montserrat",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "VMaip",
                  "fill": "#0B1120",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Rules & Limits",
                  "fontFamily": "Overpass",
                  "fontSize": 32,
                  "fontWeight": "700"
                },
                {
                  "type": "frame",
                  "id": "o3O8P",
                  "name": "faq3",
                  "width": "fill_container",
                  "fill": "#F8F5EE",
                  "cornerRadius": [
                    0,
                    32,
                    0,
                    0
                  ],
                  "layout": "vertical",
                  "gap": 16,
                  "padding": 32,
                  "children": [
                    {
                      "type": "text",
                      "id": "O1rQyY",
                      "fill": "#0B1120",
                      "content": "Q: What happens if I miss the time limit?",
                      "fontFamily": "Overpass",
                      "fontSize": 20,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "CxdMK",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "A: Brevets are not races, but they have strict time limits. If you finish outside the time limit, your ride will not be homologated by ACP, though you still accomplished a great personal feat!",
                      "lineHeight": 1.5,
                      "fontFamily": "Montserrat",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "zZqgL",
                  "name": "faq4",
                  "width": "fill_container",
                  "fill": "#F0F4F8",
                  "cornerRadius": [
                    0,
                    32,
                    0,
                    0
                  ],
                  "layout": "vertical",
                  "gap": 16,
                  "padding": 32,
                  "children": [
                    {
                      "type": "text",
                      "id": "Y0ozC",
                      "fill": "#0B1120",
                      "content": "Q: Can I take a shortcut?",
                      "fontFamily": "Overpass",
                      "fontSize": 20,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "jdLmd",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "A: No, you must follow the official route. If you leave the route (e.g. to find food or sleep), you must return to it at the exact point where you left.",
                      "lineHeight": 1.5,
                      "fontFamily": "Montserrat",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "Hq679",
                  "fill": "#0B1120",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Navigation & Support",
                  "fontFamily": "Overpass",
                  "fontSize": 32,
                  "fontWeight": "700"
                },
                {
                  "type": "frame",
                  "id": "TDXZH",
                  "name": "faq5",
                  "width": "fill_container",
                  "fill": "#F8F5EE",
                  "cornerRadius": [
                    0,
                    32,
                    0,
                    0
                  ],
                  "layout": "vertical",
                  "gap": 16,
                  "padding": 32,
                  "children": [
                    {
                      "type": "text",
                      "id": "MrFlR",
                      "fill": "#0B1120",
                      "content": "Q: How do I navigate the route?",
                      "fontFamily": "Overpass",
                      "fontSize": 20,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "L6eJp",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "A: Most riders use a GPS device loaded with the route track. We also provide printable cue sheets.",
                      "lineHeight": 1.5,
                      "fontFamily": "Montserrat",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "CUhYb",
                  "name": "faq6",
                  "width": "fill_container",
                  "fill": "#F0F4F8",
                  "cornerRadius": [
                    0,
                    32,
                    0,
                    0
                  ],
                  "layout": "vertical",
                  "gap": 16,
                  "padding": 32,
                  "children": [
                    {
                      "type": "text",
                      "id": "v1RJbC",
                      "fill": "#0B1120",
                      "content": "Q: Are there support vehicles?",
                      "fontFamily": "Overpass",
                      "fontSize": 20,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "oZVAb",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "A: Randonneuring is unsupported. You must carry your own gear and fix your own mechanical issues. Outside support is only allowed at designated control points.",
                      "lineHeight": 1.5,
                      "fontFamily": "Montserrat",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            },
